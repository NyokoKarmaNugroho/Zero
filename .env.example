# Chain
SYNAPSE_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
SOLANA_KEYPAIR_PATH=/path/to/agent-keypair.json

# Ace AI APIs (api.acedata.cloud) — worker x402 via Solana USDC + keypair above
ACEDATA_API_KEY=
ACE_API_KEY=

# Ace platform (platform.acedata.cloud) — order pay uses Base USDC + EVM key (bounty / top-up)
ACE_PLATFORM_TOKEN=
ACE_X402_PRIVATE_KEY=
# Optional: default order for `cd services/orchestrator && pnpm run pay-ace-order`
ACE_X402_ORDER_ID=

# Solana facilitator ATA (on-chain SAP routing) — not ACE_PLATFORM_TOKEN
FACILITATOR_ATA=

# Planner (OpenRouter — low volume; Ace drives bounty metrics)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MAX_TOKENS=512
# Set PLANNER_ENABLED=false to always use fixed ace-chat/image/video steps (cheapest)
PLANNER_ENABLED=true

# gRPC / HTTP
CHAIN_GRPC_ADDR=127.0.0.1:50051
GATEWAY_HTTP_ADDR=:8080
# Required in production — POST /v1/runs sends X-API-Key or Authorization: Bearer
GATEWAY_API_KEY=
GATEWAY_RATE_LIMIT_RPM=30

# Run state & routing
STATE_DIR=./state
ESCROW_THRESHOLD_USD=100
MAX_ESCROW_USD=10
MAX_JOB_QUERY_LEN=2000
WORKER_MAX_RUNS_PER_HOUR=60
JITTER_MIN_MS=30000
JITTER_MAX_MS=180000
WORKER_LOOP=false

# Spawn / cloud (operator machine only)
HCLOUD_TOKEN=
